# ─── Site ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://getcapsignal.com

# ─── Database (local dev) ───────────────────────────────────────────────────
# Production: use Turso/Postgres — SQLite file DB does not persist on Vercel.
DATABASE_URL="file:./dev.db"

# ─── Auth ───────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=https://getcapsignal.com
# Comma-separated emails allowed to access /admin (uses same login as dashboard)
ADMIN_EMAILS=hello@getcapsignal.com,christianfm801@gmail.com

# ─── Stripe (required for /checkout) ────────────────────────────────────────
# Dashboard → Developers → API keys → Secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=sk_test_...
# Dashboard → Products → CapSignal $99.99/mo → Price ID (price_...)
STRIPE_PRICE_CAPSIGNAL=price_...
# Dashboard → Developers → Webhooks → Add endpoint → signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Leads ──────────────────────────────────────────────────────────────────
LEAD_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...
LEAD_NOTIFY_EMAIL=hello@getcapsignal.com,christianfm801@gmail.com
LEAD_FROM_EMAIL=CapSignal <hello@getcapsignal.com>
LEAD_REPLY_TO_EMAIL=hello@getcapsignal.com
FOUNDER_FROM_EMAIL=Christian Myers <hello@getcapsignal.com>
# Optional Calendly (or similar) link included in founder drop-off emails
# FOUNDER_CALL_URL=
RESEND_API_KEY=

# ─── Analytics (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
# Microsoft Clarity — free heatmaps, scroll maps, session recordings (clarity.microsoft.com)
NEXT_PUBLIC_CLARITY_ID=
# Bookmark once to opt out of visitor session emails on your browser: /?cs_internal=YOUR_KEY
NEXT_PUBLIC_INTERNAL_ANALYTICS_KEY=
# Session report emails are Google Ads only by default (gclid/gad_* or utm_source=google&utm_medium=cpc)
# VISITOR_REPORTS_ALL=true
# Comma-separated IPs to exclude from session report emails (home/office)
# VISITOR_EXCLUDE_IPS=
# Comma-separated user-agent substrings to exclude (defaults include SearchBot,bot,spider,crawler)
# VISITOR_EXCLUDE_UA=
# Optional overrides for end-of-session visitor report emails (uses LEAD_NOTIFY_EMAIL + LEAD_FROM_EMAIL by default)
# VISITOR_NOTIFY_EMAIL=
# VISITOR_FROM_EMAIL=
