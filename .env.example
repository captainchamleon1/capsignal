# ─── Site ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://getcapsignal.com

# ─── Database (local dev) ───────────────────────────────────────────────────
# Production: use Turso/Postgres — SQLite file DB does not persist on Vercel.
DATABASE_URL="file:./dev.db"

# ─── Auth ───────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=https://getcapsignal.com

# ─── Stripe (required for /checkout) ────────────────────────────────────────
# Dashboard → Developers → API keys → Secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=sk_test_...
# Dashboard → Products → CapSignal $99.99/mo → Price ID (price_...)
STRIPE_PRICE_CAPSIGNAL=price_...

# ─── Leads ──────────────────────────────────────────────────────────────────
LEAD_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...
LEAD_NOTIFY_EMAIL=hello@getcapsignal.com
RESEND_API_KEY=

# ─── Analytics (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
